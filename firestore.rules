rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - age: number (required, 8-120) - User's age
    //   - height: number (required, 50-250) - User's height in cm
    //   - weight: number (required, 20-300) - User's weight in kg
    //   - gender: string (required, 'Male'|'Female'|'Other') - User's gender
    //   - preference: string (required, 'Vegetarian'|'Non-Vegetarian') - Diet preference
    //   - activityLevel: string (required) - Activity level description
    //   - goal: string (required) - Fitness goal
    //   - ageGroup: string (required) - Calculated age group
    //
    // Collection: workouts
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - Owner's UID
    //   - date: string (required, ISO 8601) - Workout date
    //   - durationMinutes: number (required, > 0) - Duration in minutes
    //   - exercises: list (required, strings) - List of exercises performed
    //   - totalReps: number (required, >= 0) - Total repetitions
    //   - ageGroup: string (required) - Age group at time of workout
    //
    // ===============================================================

    // Collection: diet_plans
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - plan: object (required) - DietPlan structure
    //   - insight: string (required) - AI insight
    //   - lastUpdated: string (required) - ISO 8601 timestamp
    //
    // Collection: workout_history
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - records: list (required) - Array of WorkoutRecord objects
    //   - lastUpdated: string (required) - ISO 8601 timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ameyshinde1210@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'age', 'height', 'weight', 'gender', 'preference', 'activityLevel', 'goal', 'ageGroup']) &&
             data.uid == request.auth.uid &&
             data.age is number && data.age >= 8 && data.age <= 120 &&
             data.height is number && data.height >= 50 && data.height <= 250 &&
             data.weight is number && data.weight >= 20 && data.weight <= 300 &&
             data.gender in ['Male', 'Female', 'Other'] &&
             data.preference in ['Vegetarian', 'Non-Vegetarian'];
    }

    function isValidWorkout(data) {
      return hasRequiredFields(['uid', 'date', 'durationMinutes', 'exercises', 'totalReps', 'ageGroup']) &&
             data.uid == request.auth.uid &&
             data.durationMinutes is number && data.durationMinutes > 0 &&
             data.exercises is list && data.exercises.size() <= 50 &&
             data.totalReps is number && data.totalReps >= 0;
    }

    function isValidDietPlan(data) {
      return hasRequiredFields(['plan', 'insight', 'lastUpdated']) &&
             data.plan is map &&
             data.insight is string &&
             data.lastUpdated is string;
    }

    function isValidWorkoutHistory(data) {
      return hasRequiredFields(['records', 'lastUpdated']) &&
             data.records is list &&
             data.lastUpdated is string;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();
    }

    match /diet_plans/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidDietPlan(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /workout_history/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidWorkoutHistory(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /workouts/{workoutId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidWorkout(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidWorkout(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
